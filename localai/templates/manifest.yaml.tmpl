# ------------------------------------------------------------------
# MASTER
# ------------------------------------------------------------------
apiVersion: apps/v1
kind: Deployment
metadata:
  name: local-ai-{{ .group }}
  namespace: local-ai
  labels:
    app: {{ .group }}_master
    group: "{{ .group }}"
    role: master
spec:
  selector:
    matchLabels:
      app: {{ .group }}_master
  replicas: 1
  template:
    metadata:
      labels:
        app: {{ .group }}_master
        group: "{{ .group }}"
        role: master
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "{{ .portbind }}"
        prometheus.io/path: "/metrics"
        localai-backends-path: "/backends/amd64"
    spec:
      schedulerName: {{ .schedulerName }}
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
      {{ if .masterHostname }}
      nodeSelector:
        kubernetes.io/hostname: {{ .masterHostname }}
      {{ else }}
      nodeSelector:
        kubernetes.io/arch: amd64
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: node-role.kubernetes.io/control-plane
                    operator: DoesNotExist
                  - key: node-role
                    operator: NotIn
                    values:
                      - management
      {{ end }}
      {{ if .useGPU }}
      runtimeClassName: "nvidia"
      {{ end }}
      containers:
        - name: local-ai
          image: localai/localai:master-aio-cpu
          imagePullPolicy: IfNotPresent
          args:
            - run
            - --p2p
            - "--address"
            - ":{{ .portbind }}"
            - --p2ptoken
            - "{{ .p2pToken }}"
          env:
            - name: DEBUG
              value: "true"
            - name: MODELS
              value: "[]"
            - name: LOCALAI_BACKENDS_PATH
              valueFrom:
                fieldRef:
                  fieldPath: metadata.annotations['localai-backends-path']
          {{ if .useGPU }}
          resources:
            limits:
              nvidia.com/gpu.shared: 1
          {{ end }}
          volumeMounts:
            - name: local-models
              mountPath: /models
            - name: local-backends
              mountPath: /backends
      volumes:
        - name: local-models
          persistentVolumeClaim:
            claimName:  {{ .models_pvc or "localai-shared-models-pvc"}}
        - name: local-backends
          persistentVolumeClaim:
            claimName: {{ .backend_pvc or "localai-backend-all-pvc"}}
---
apiVersion: v1
kind: Service
metadata:
  name: local-ai-{{ .group }}
  namespace: local-ai
  labels:
    app: {{ .group }}_master
    group: "{{ .group }}"
spec:
  selector:
    app: {{ .group }}_master
  type: ClusterIP
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: {{ .portbind }}

# ------------------------------------------------------------------
# WORKER (una Deployment per worker, porte sequenziali)
# ------------------------------------------------------------------
{{ range $i := until (or .numWorker 0) }}
{{ $workerPort := add $.workerBasePort $i }}
{{ $workerSuffix := printf "%s-%d" (or $.workerNodeName "worker") $workerPort }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: localai-worker-{{ $.group }}-{{ $workerSuffix }}
  namespace: local-ai
  labels:
    app: {{ $.group }}_worker_{{ $workerSuffix }}
    group: "{{ $.group }}"
    role: worker
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ $.group }}_worker_{{ $workerSuffix }}
  template:
    metadata:
      labels:
        app: {{ $.group }}_worker_{{ $workerSuffix }}
        group: "{{ $.group }}"
        role: worker
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "2112"
        localai-backends-path: "/backends/amd64"
        localai-worker-args: "p2p-worker p2p-llama-cpp-rpc"
    spec:
      schedulerName: {{ $.schedulerName }}
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
      serviceAccountName: localai-worker-sidecar
      nodeSelector:
        {{ if $.workerNodeName }}
        kubernetes.io/hostname: {{ $.workerNodeName }}
        {{ else }}
        {}
        {{ end }}
      containers:
        - name: worker
          image: localai/localai:master-cpu
          imagePullPolicy: IfNotPresent
          args:
            - $(WORKER_ARGS)
            - p2p-llama-cpp-rpc
          env:
            - name: DEBUG
              value: "true"
            - name: TOKEN
              value: "{{ $.p2pToken }}"
            - name: MODELS
              value: "[]"
            - name: LOCALAI_LOG_LEVEL
              value: "debug"
            - name: LOCALAI_BACKENDS_PATH
              valueFrom:
                fieldRef:
                  fieldPath: metadata.annotations['localai-backends-path']
            - name: WORKER_ARGS
              valueFrom:
                fieldRef:
                  fieldPath: metadata.annotations['localai-worker-args']
          {{ if $.workerMemoryLimitGi }}
          resources:
            limits:
              memory: "{{ $.workerMemoryLimitGi }}Gi"
          {{ end }}
          volumeMounts:
            - name: local-backends
              mountPath: /backends
        - name: worker-watcher
          image: dami00/localai-worker-sidecar:latest
          imagePullPolicy: Always
          env:
            - name: NODE_NAME
              valueFrom:
                fieldRef:
                  fieldPath: spec.nodeName
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
            - name: TOKEN
              value: "{{ $.p2pToken }}"
            - name: CLUSTER_ID
              value: "{{ $.group }}"
      volumes:
        - name: local-backends
          persistentVolumeClaim:
            claimName: {{ .backend_pvc or "localai-backend-all-pvc"}}
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: node-role.kubernetes.io/control-plane
                    operator: DoesNotExist
                  - key: node-role
                    operator: NotIn
                    values:
                      - management
{{ end }}

# ------------------------------------------------------------------
# GATEWAY PER-MASTER (nginx)
# ------------------------------------------------------------------
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: gateway-{{ .group }}-config
  namespace: local-ai
  labels:
    group: "{{ .group }}"
    app: gateway-{{ .group }}
data:
  default.conf: |
    server {
      listen 8080;

      location / {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass http://local-ai-{{ .group }}:8080;
      }
    }
{{ range .proxyNodes }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway-{{ .group }}
  namespace: local-ai
  labels:
    group: "{{ .group }}"
    app: gateway-{{ .group }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway-{{ .group }}
  template:
    metadata:
      labels:
        group: "{{ .group }}"
        app: gateway-{{ .group }}
    spec:
      schedulerName: {{ .schedulerName }}
      containers:
        - name: nginx
          image: nginx:1.27-alpine
          ports:
            - name: http
              containerPort: 8080
          volumeMounts:
            - name: nginx-config
              mountPath: /etc/nginx/conf.d/default.conf
              subPath: default.conf
          resources:
            requests:
              cpu: 25m
              memory: 32Mi
            limits:
              cpu: 250m
              memory: 128Mi
      volumes:
        - name: nginx-config
          configMap:
            name: gateway-{{ .group }}-config
{{ end }}
---
apiVersion: v1
kind: Service
metadata:
  name: node-proxy
  namespace: local-ai
  labels:
    group: "{{ .group }}"
    app: gateway-{{ .group }}
    component: node-proxy
spec:
  type: NodePort
  externalTrafficPolicy: Local
  selector:
    app: gateway-{{ .group }}
  ports:
    - name: http
      port: 80
      targetPort: 8080
      {{ if .gatewayNodePort }}nodePort: {{ .gatewayNodePort }}{{ end }}