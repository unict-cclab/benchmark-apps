apiVersion: v1
kind: Service
metadata:
  name: node-proxy
  labels:
    group: {{ .group }}
    component: node-proxy
spec:
  type: NodePort
  externalTrafficPolicy: Local
  selector:
    group: {{ .group }}
    component: node-proxy
  ports:
  - name: http
    port: 80
    targetPort: 8080
