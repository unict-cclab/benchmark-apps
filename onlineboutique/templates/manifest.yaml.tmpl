    value: "{{ $.cpa.timeRange }}"
  - name: REDIS_HOST
    value: "{{ $.cpa.redisHost }}"
  - name: MIN_REPLICAS
    value: "{{ $.cpa.minReplicas }}"
  - name: MAX_REPLICAS
    value: "{{ $.cpa.maxReplicas }}"
  - name: KP
    value: "{{ $.cpa.kp }}"
  - name: KI
    value: "{{ $.cpa.ki }}"
  - name: KD
